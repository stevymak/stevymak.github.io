rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwnerUid(uid) {
      return signedIn() && uid != null && request.auth.uid == uid;
    }

    function isOwnerEmail(email) {
      return signedIn()
        && email is string
        && request.auth.token.email is string
        && request.auth.token.email == email;
    }

    function reservationMutableFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'service',
        'dateKey',
        'time',
        'timeLabel',
        'heure',
        'adresse',
        'modificationNote',
        'modifiedAt',
        'status'
      ]);
    }

    function reservationClientUpdateAllowed() {
      return request.resource.data.status in ['pending', 'cancelled']
        && reservationMutableFieldsOnly();
    }

    function validReservationCreate() {
      return request.resource.data.keys().hasAll([
        'service',
        'dateKey',
        'timeLabel',
        'price',
        'nom',
        'telephone',
        'email',
        'adresse',
        'status',
        'createdAt'
      ])
      && (!('uid' in request.resource.data)
        || (signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email))
      && request.resource.data.service is string
      && request.resource.data.dateKey is string
      && request.resource.data.timeLabel is string
      && request.resource.data.nom is string
      && request.resource.data.telephone is string
      && request.resource.data.email is string
      && request.resource.data.adresse is string
      && request.resource.data.status == 'pending';
    }

    function validContractCreate() {
      return request.resource.data.keys().hasAll([
        'contrat',
        'nom',
        'email',
        'telephone',
        'adresse',
        'status',
        'createdAt'
      ])
      && (!('uid' in request.resource.data)
        || (signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email))
      && request.resource.data.contrat in ['serenite', 'senior', 'famille']
      && request.resource.data.nom is string
      && request.resource.data.email is string
      && request.resource.data.telephone is string
      && request.resource.data.adresse is string
      && request.resource.data.status == 'new';
    }

    function validClientMessageCreate() {
      return request.resource.data.keys().hasAll([
        'uid',
        'email',
        'sujet',
        'texte',
        'createdAt',
        'lu'
      ])
      && request.resource.data.uid == request.auth.uid
      && request.resource.data.email == request.auth.token.email
      && request.resource.data.sujet is string
      && request.resource.data.texte is string
      && request.resource.data.lu == false;
    }

    match /reservations/{reservationId} {
      allow read: if isAdmin() || isOwnerUid(resource.data.uid);

      // Public creation remains allowed for the current public booking flow.
      // Prefer migrating this to a backend or authenticated flow.
      allow create: if validReservationCreate();

      allow update: if isAdmin()
        || (isOwnerUid(resource.data.uid) && reservationClientUpdateAllowed());

      allow delete: if isAdmin();
    }

    match /contrats/{contratId} {
      allow read: if isAdmin() || isOwnerUid(resource.data.uid) || isOwnerEmail(resource.data.email);

      allow create: if validContractCreate();

      allow update, delete: if isAdmin();
    }

    match /messages_clients/{messageId} {
      allow create: if signedIn() && validClientMessageCreate();
      allow read, update, delete: if isAdmin();
    }

    match /avis/{avisId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /avis_en_attente/{avisId} {
      allow create: if request.resource.data.keys().hasAll([
        'nom',
        'comment',
        'note',
        'createdAt',
        'statut'
      ])
      && request.resource.data.nom is string
      && request.resource.data.comment is string
      && request.resource.data.note is int
      && request.resource.data.note >= 1
      && request.resource.data.note <= 5
      && request.resource.data.statut == 'en_attente';

      allow read, update, delete: if isAdmin();
    }

    match /devis_web/{devisId} {
      // Current public lead form.
      allow create: if request.resource.data.keys().hasAll([
        'type',
        'description',
        'budget',
        'delai',
        'nom',
        'email',
        'createdAt'
      ]);
      allow read, update, delete: if isAdmin();
    }

    // Méta-données client enrichies (tags, notes privées) gérées par
    // l'admin uniquement. Le doc id est un hash court (SHA-256 tronqué)
    // de l'email lowercase ou du téléphone normalisé.
    match /clients_meta/{hashId} {
      allow read, write: if isAdmin();
    }

    // Factures émises (admin only). Numérotation séquentielle gérée
    // via la collection counters/.
    match /factures/{factureId} {
      allow read, write: if isAdmin();
    }

    // Devis (admin only). Numérotation séquentielle gérée via counters/.
    // Conversion devis → facture : on crée un nouveau doc factures + on
    // met à jour le statut du devis avec factureId.
    match /devis/{devisId} {
      allow read, write: if isAdmin();
    }

    // Compteurs séquentiels (factures, devis…). Document id de la
    // forme `factures-2026` ou `devis-2026`. Mis à jour atomiquement
    // par l'admin via runTransaction côté client.
    match /counters/{counterId} {
      allow read, write: if isAdmin();
    }

    // Templates d'emails réutilisables (newsletter, fiche, promo, relance).
    match /templates/{tplId} {
      allow read, write: if isAdmin();
    }

    // Bibliothèque de fiches pratiques (liens PDF, catégories).
    // Les fiches peuvent être référencées dans les emails (variables
    // {{fiche_url}}) ou listées sur le site public.
    match /fiches_pdf/{ficheId} {
      allow read:  if true;          // catalogue public
      allow write: if isAdmin();
    }

    // Paramètres globaux de l'admin (automations, préférences).
    // Doc id de la forme `automations`, `general`…
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // Campagnes d'envoi (newsletters, promos…). Stats remplies par le
    // webhook Resend côté Cloud Functions.
    match /campagnes/{campId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
